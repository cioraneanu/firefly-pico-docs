ion. You can even use your phone's dictation for a hands-free experience! 📢",[83,84,86],"h2",{"id":85},"format","Format",[79,88,89,90],{},"The basic format is:\n",[91,92,93],"code",{},"[Tag / Category / Template] [Amount?] [Description?] [Todo?]",[95,96,98],"h3",{"id":97},"parts","Parts",[100,101,102,127,133,139],"ol",{},[103,104,105,106,110,111,114,115,118,119,122,123,126],"li",{},"The first part tries to identify the transaction type via fuzzy searching your ",[107,108,109],"strong",{},"tags",", ",[107,112,113],{},"categories","\nand ",[107,116,117],{},"templates"," (e.g., ",[91,120,121],{},"elct"," => ",[91,124,125],{},"electricity",").",[103,128,129,132],{},[107,130,131],{},"Amount:"," (optional) Supports mathematical expressions. Numbers separated by a space are automatically added up.",[103,134,135,138],{},[107,136,137],{},"Description:"," (optional). If provided overwrites the default value (tag name / template description).",[103,140,141,144,145,148],{},[107,142,143],{},"Todo:"," (optional) Appending a custom string (default ",[91,146,147],{},"!!",") marks the transaction as a \"Todo\". This string is configurable in Settings.",[83,150,152],{"id":151},"examples","Examples",[79,154,155],{},"Assuming you have:",[157,158,159,165],"ul",{},[103,160,161,164],{},[107,162,163],{},"Tag",": \"Electricity\"",[103,166,167,170],{},[107,168,169],{},"Template",": \"Swimming\"",[172,173,174,187],"table",{},[175,176,177],"thead",{},[178,179,180,184],"tr",{},[181,182,183],"th",{},"Input",[181,185,186],{},"Result",[188,189,190,201,211,221,231],"tbody",{},[178,191,192,198],{},[193,194,195],"td",{},[91,196,197],{},"electricity 23",[193,199,200],{},"Tag: Electricity, Amount: 23",[178,202,203,208],{},[193,204,205],{},[91,206,207],{},"elc 12*2+33",[193,209,210],{},"Tag: Electricity, Amount: 57",[178,212,213,218],{},[193,214,215],{},[91,216,217],{},"elc 12+2*3 custom description",[193,219,220],{},"Tag: Electricity, Amount: 18, Description: \"custom description\"",[178,222,223,228],{