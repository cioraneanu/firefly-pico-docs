[{"data":1,"prerenderedAt":242},["ShallowReactive",2],{"navigation_docs":3,"-introduction":73,"-introduction-surround":239},[4,10,24,41,50,60],{"title":5,"path":6,"stem":7,"children":8},"Introduction","/introduction","0.introduction/index",[9],{"title":5,"path":6,"stem":7},{"title":11,"path":12,"stem":13,"children":14,"page":23},"Installation","/installation","1.installation",[15,19],{"title":16,"path":17,"stem":18},"Docker","/installation/docker","1.installation/1.docker",{"title":20,"path":21,"stem":22},"From source","/installation/manual","1.installation/2.manual",false,{"title":25,"path":26,"stem":27,"children":28,"page":23},"Features","/features","2.features",[29,33,37],{"title":30,"path":31,"stem":32},"Templates","/features/templates","2.features/1.templates",{"title":34,"path":35,"stem":36},"Assistant","/features/assistant","2.features/2.assistant",{"title":38,"path":39,"stem":40},"Profiles","/features/profiles","2.features/3.profiles",{"title":42,"path":43,"stem":44,"children":45,"page":23},"Guide","/guide","3.guide",[46],{"title":47,"path":48,"stem":49},"App usage","/guide/usage","3.guide/1.usage",{"title":51,"path":52,"stem":53,"children":54},"Contributing","/contribute","4.contribute/1.index",[55,56],{"title":51,"path":52,"stem":53},{"title":57,"path":58,"stem":59},"Localization","/contribute/localization","4.contribute/2.localization",{"title":61,"path":62,"stem":63,"children":64,"page":23},"About","/about","5.about",[65,69],{"title":66,"path":67,"stem":68},"Architecture","/about/architecture","5.about/0.architecture",{"title":70,"path":71,"stem":72},"Attribution","/about/attribution","5.about/1.attribution",{"id":74,"title":5,"body":75,"description":232,"extension":233,"links":234,"meta":235,"navigation":236,"path":6,"seo":237,"stem":7,"__hash__":238},"docs/0.introduction/index.md",{"type":76,"value":77,"toc":223},"minimark",[78,87,92,110,113,119,122,128,133,183,188,192],[79,80,82],"div",{"style":81},"text-align: center;",[83,84],"img",{"alt":85,"src":86},"Presentation","/images/presentation.png",[88,89,91],"h2",{"id":90},"about","💡 About",[93,94,95,99,100,109],"p",{},[96,97,98],"strong",{},"Firefly-Pico"," is a mobile-optimized, highly responsive web application designed as a ",[96,101,102],{},[103,104,108],"a",{"href":105,"rel":106},"https://github.com/firefly-iii/firefly-iii",[107],"nofollow","Firefly III"," companion app.",[93,111,112],{},"It is built with a focus on speed and ease of use,\nallowing you to quickly log expenses, organize tags, and keep track of your finances\non the go, all while maintaining completely private control over your own data.",[93,114,115,116,118],{},"Apart from the sleek interface, it augments ",[96,117,108],{}," with custom entity icons,\nsupport for sub-tags, and \"templates\" for auto-filling the transaction form.",[93,120,121],{},"Last but not least, it also comes with a smart \"assistant\" which makes recording expenses a breeze 🎉:",[93,123,124],{},[83,125],{"alt":34,"src":126,"style":127},"/video/assistant.gif","width: 300px",[129,130,132],"h3",{"id":131},"the-assistant-in-action","The Assistant in Action",[134,135,136,150],"table",{},[137,138,139],"thead",{},[140,141,142,147],"tr",{},[143,144,146],"th",{"align":145},"left","Action",[143,148,149],{"align":145},"Result",[151,152,153],"tbody",{},[140,154,155,166],{},[156,157,158,159,162,163,165],"td",{"align":145},"Write \"tag\" + \"amount\" ",[160,161],"br",{}," ",[160,164],{}," Ex. \"elctr 28\"",[156,167,168,169,171,172,174,175,177,178,162,180,182],{"align":145},"- Fuzzy search finds \"electricity,\" sets your tag, category and description, ",[160,170],{}," - Sets the date to \"now,\" ",[160,173],{}," - Sets Amount to 28",[160,176],{}," - Sets your default asset account.",[160,179],{},[160,181],{}," Just hit \"Save\"",[93,184,185],{},[103,186,187],{"href":35},"Assistant Tutorial",[88,189,191],{"id":190},"features","🚀 Features",[193,194,195,199,202,205,208,211,214,217,220],"ul",{},[196,197,198],"li",{},"✅ Beautiful clean minimalistic UI 🔥 subtle animations and dark-theme support 🌛",[196,200,201],{},"✅ Optimized for mobile, with PWA support for a native feel 📱",[196,203,204],{},"✅ The Assistant makes recording an expense feel like magic ✨",[196,206,207],{},"✅ Expand Firefly data with icons for all resources 🎨",[196,209,210],{},"✅ Expand Firefly \"tags\" with the option of subtags for better granularity",[196,212,213],{},"✅ Add \"templates\" to make auto-completing fields a breeze 📢",[196,215,216],{},"✅ Beautiful dashboard making it easy to keep an eye on everything that matters 📈",[196,218,219],{},"✅ Lots of tweaks and settings 🔧",[196,221,222],{},"✅ Free and open-source",{"title":224,"searchDepth":225,"depth":225,"links":226},"",2,[227,231],{"id":90,"depth":225,"text":91,"children":228},[229],{"id":131,"depth":230,"text":132},3,{"id":190,"depth":225,"text":191},"A delightful Firefly III companion web app for effortless transaction tracking.","md",null,{},true,{"title":5,"description":232},"PovvcqHAnjUHEyL8is5f3353NNJzOcESlwTQQRWgi6Q",[234,240],{"title":16,"path":17,"stem":18,"description":241,"children":-1},"Learn how to install Firefly Pico using Docker or manually.",1774611298733]